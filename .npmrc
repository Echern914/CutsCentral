auto-install-peers=true
strict-peer-dependencies=false

# React Native / Metro (apps/mobile) expect a FLAT node_modules. EAS Build runs
# `pnpm install` at this ROOT, so the hoist must live here (a per-app .npmrc is
# not applied during that root install). pnpm's default symlinked layout breaks
# RN's resolver - it can't find transitive deps like @babel/runtime. node-linker
# =hoisted installs a flat node_modules for the whole workspace; this only changes
# the on-disk LAYOUT, not which versions resolve, and the api/web/db suites are
# re-verified against it. This is Expo's recommended pnpm + EAS configuration.
node-linker=hoisted
