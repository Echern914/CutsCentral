# =============================================================
# ChairBack - environment variables (multi-tenant)
# Copy to .env and fill in. Validated with Zod at boot; missing vars crash loudly.
# =============================================================

# Database (Supabase Postgres)
# Supabase gives two connection strings (Project Settings to Database to Connection string):
#   DATABASE_URL = "Transaction pooler" (host has -pooler, port 6543) - used by the app at runtime.
#                  Append ?pgbouncer=true&connection_limit=N.
#   DIRECT_URL   = "Direct connection" (port 5432) - used by `prisma migrate` only.
#
#   SIZING connection_limit (a SCALABILITY knob, not boilerplate):
#   The API is ONE long-lived process on Railway, not a fleet of serverless
#   functions. Every tenant query runs inside a transaction (runWithShop), so a
#   pool of 1 SERIALIZES all concurrent requests behind a single connection and
#   the API stalls under load. `connection_limit=1` is the *serverless* recipe
#   (many short-lived instances, one conn each) and is WRONG for this process.
#   Use a real pool: 10 is a safe one-replica default; raise toward ~20 if you
#   see request queueing. Keep it under the Supabase pooler "Pool Size" budget;
#   if you ever run MULTIPLE replicas, (per-replica limit x replicas) must stay
#   under that budget.
DATABASE_URL="postgresql://postgres.PROJECTREF:PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=10"
DIRECT_URL="postgresql://postgres.PROJECTREF:PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres"

# Test database (REQUIRED to run the API test suite). The tests create and
# delete shops, so they MUST point at a throwaway DB - never production. The
# test bootstrap (apps/api/vitest.setup.ts) refuses to run against a Supabase
# host unless this is set. Use a local Postgres or a separate Supabase project.
#   e.g. local:  postgresql://postgres:postgres@localhost:5432/chairback_test
# TEST_DATABASE_URL="postgresql://postgres:postgres@localhost:5432/chairback_test"

# Public origins
APP_BASE_URL="http://localhost:3000"          # web app origin (used in rewards magic links)
API_BASE_URL="http://localhost:4000"          # api origin (used to build per-shop webhook target URLs)

# Secrets
SESSION_SECRET="change-me-32-bytes-min-random-string"      # signs barber session cookies
TOKEN_ENCRYPTION_KEY="change-me-base64-32-bytes"           # AES-256-GCM key for Acuity tokens at rest
                                                           # generate: openssl rand -base64 32
ADMIN_TOKEN="change-me-platform-operator-token"            # guards /admin/* (backfill, nudge-sweep)
# Optional IP allowlist for the operator surface (/admin + /api/admin-portal). Comma-separated
# IPs; when set, ANY other IP gets a 404 even with valid admin creds. LEAVE BLANK to disable
# (fail-open) so you can't lock yourself out. Find your IP at https://ifconfig.me ; on Railway
# the app sees the real client IP. Re-deploy after changing (read once at boot).
ADMIN_IP_ALLOWLIST=""

# Acuity OAuth2 app (register once at https://acuityscheduling.com/oauth2/register)
ACUITY_OAUTH_CLIENT_ID="your-acuity-client-id"
ACUITY_OAUTH_CLIENT_SECRET="your-acuity-client-secret"
ACUITY_OAUTH_REDIRECT_URI="http://localhost:4000/api/acuity/oauth/callback"

# Google sign-in (optional). Create an OAuth 2.0 Client (Web application) at
# https://console.cloud.google.com/apis/credentials and set the redirect URI below.
GOOGLE_OAUTH_CLIENT_ID=""
GOOGLE_OAUTH_CLIENT_SECRET=""
GOOGLE_OAUTH_REDIRECT_URI="http://localhost:4000/api/auth/google/callback"

# Twilio (ONE shared platform number for all shops; shop name goes in the message body)
TWILIO_ACCOUNT_SID="ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
TWILIO_AUTH_TOKEN="your-twilio-auth-token"
TWILIO_FROM_NUMBER="+15551234567"

# Web Push (VAPID) - the FREE, push-first alternative to SMS for the rewards PWA.
# Generate a keypair with: npx web-push generate-vapid-keys
# Optional: while any of the three is unset, push is dormant and sends fall back
# to SMS. Use a SEPARATE keypair per environment (don't reuse dev keys in prod).
#  - PUBLIC key  -> set on BOTH api and web (it's a public key, safe in the browser)
#  - PRIVATE key -> api ONLY (signs each push; never ship it to the browser)
#  - SUBJECT     -> a mailto: or https URL; your contact for the push services
PUSH_VAPID_PUBLIC_KEY=""
PUSH_VAPID_PRIVATE_KEY=""
PUSH_VAPID_SUBJECT="mailto:you@example.com"

# Nudge engine defaults (applied to new shops; per-shop values live in the DB)
NUDGE_DEFAULT_BUFFER_DAYS="7"
NUDGE_DEFAULT_DAILY_CAP="50"

# Operational flags
DB_RLS_ENFORCE="true"         # SET ROLE chairback_app per tenant tx so RLS enforces (run RLS migrations first)
ENABLE_SCHEDULER="false"      # set true to run node-cron jobs in the api process (single replica only)
DRY_RUN="true"                # true = nudge sweep logs instead of sending SMS
LOG_LEVEL="info"
NODE_ENV="development"

# Dev-only: lets the seed script connect a test shop without a live OAuth round-trip.
# Paste a real Acuity access token to test engines against a live account, or leave blank.
DEV_SEED_ACUITY_ACCESS_TOKEN=""
DEV_SEED_ACUITY_ACCOUNT_ID=""

# -------- Stripe (platform SUBSCRIPTION billing) --------
# All three required to enforce trials/subscriptions; absent = billing disabled.
STRIPE_SECRET_KEY=""           # sk_test_... (also used by Connect below)
STRIPE_PRICE_ID=""             # the one subscription price
STRIPE_WEBHOOK_SECRET=""       # whsec_... for the platform (account) webhook

# -------- Stripe Connect (per-barber CUSTOMER payments) --------
# Lets barbers connect their own Stripe (Express) and charge customers at booking.
# Reuses STRIPE_SECRET_KEY above; needs a SEPARATE "Connected accounts" webhook
# pointed at /webhooks/stripe-connect. Absent = payments feature stays dark.
STRIPE_CONNECT_WEBHOOK_SECRET="" # whsec_... for the Connect webhook (Railway)
# Publishable key for the browser Payment Element. NEXT_PUBLIC_ = exposed to the
# client by design. Set this in the WEB app env (Vercel), not the API.
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="" # pk_test_... (Vercel)

# -------- Transactional email (Resend) --------
# Both required for forgot-password + trial-expiry reminder emails; absent =
# email disabled (sends no-op, the forgot-password link hides itself). The
# EMAIL_FROM domain must be DNS-verified in the Resend dashboard first.
# DRY_RUN=true suppresses real email sends the same way it suppresses SMS.
RESEND_API_KEY=""              # re_... from resend.com/api-keys
EMAIL_FROM=""                  # e.g. "ChairBack <hello@getchairback.com>"

# -------- AI receptionist (Anthropic) --------
# ANTHROPIC_API_KEY absent = the whole receptionist feature is dark (inbound
# webhook keeps STOP/START-only behavior, no gap-fill outreach). The system
# prompt is loaded AT RUNTIME from ai/receptionist-prompt.md (repo root);
# RECEPTIONIST_PROMPT_PATH overrides that location. DRY_RUN=true suppresses the
# receptionist's real SMS sends like every other send path.
ANTHROPIC_API_KEY=""           # sk-ant-... from console.anthropic.com
RECEPTIONIST_MODEL=""          # optional; default claude-sonnet-5
RECEPTIONIST_PROMPT_PATH=""    # optional; default <repo>/ai/receptionist-prompt.md
# Stripe price for the $40/mo receptionist add-on. Unset = self-serve upgrade
# unavailable; only receptionistCompAccess (comped pilot) shops can enable it.
STRIPE_RECEPTIONIST_PRICE_ID="" # price_... (Railway)
