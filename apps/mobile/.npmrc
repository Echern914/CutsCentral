# React Native / Metro expect a FLAT node_modules. pnpm's default symlinked,
# strictly-nested layout breaks RN's resolver (e.g. it can't find the transitive
# @babel/runtime that Babel's compiled output imports). Hoist this package's deps
# into a flat node_modules so Metro and the native build resolve everything.
# Scoped to apps/mobile only - the rest of the monorepo keeps pnpm's default.
node-linker=hoisted
