{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "pnpm install --prod=false && pnpm --filter @chairback/api build"
  },
  "deploy": {
    "startCommand": "pnpm --filter @chairback/db migrate:deploy && pnpm --filter @chairback/api start",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 3,
    "healthcheckPath": "/healthz",
    "healthcheckTimeout": 300
  }
}
