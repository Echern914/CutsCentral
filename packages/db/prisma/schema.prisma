// ChairBack - multi-tenant data model.
// See the implementation plan for the idempotency vs tenant-scoping rationale.

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/client"
}

datasource db {
  provider  = "postgresql"
  // Supabase: pooled connection (PgBouncer, port 6543) for the app at runtime.
  url       = env("DATABASE_URL")
  // Supabase: direct connection (port 5432) for migrations / introspection.
  directUrl = env("DIRECT_URL")
}

enum VisitStatus {
  SCHEDULED
  COMPLETED
  CANCELED
  RESCHEDULED
  NO_SHOW
}

enum NudgeStatus {
  PENDING // write-ahead row, before dispatch
  SENT
  FAILED
  SKIPPED // dry-run / cap-hit, recorded for audit
}

// Where a shop takes its bookings. Exactly ONE source is active per shop - the
// native engine and Acuity never run together (no merged-calendar reconciliation).
//   link   = link out to bookingUrl (Acuity/Squarespace/etc.) - today's default.
//   acuity = the Acuity OAuth + webhook sync owns the calendar (read into Visits).
//   native = ChairBack's own booking engine (Staff/Service/Availability/Appointment).
enum BookingMode {
  link
  acuity
  native
  square // Square Appointments OAuth + webhook sync owns the calendar
}

// Lifecycle of a NATIVE Appointment (separate from VisitStatus on purpose - a
// booking is a future hold, not yet a loyalty event). No RESCHEDULED state: a
// reschedule mutates startsAt/endsAt in place and stays BOOKED.
enum AppointmentStatus {
  // PENDING = a public request awaiting barber approval (request-before-booking).
  // Holds the slot like BOOKED, but is NOT reminded/promoted/earns-loyalty; the
  // barber approves it -> BOOKED (+ confirmation fires) or declines it -> CANCELED.
  PENDING
  BOOKED
  CANCELED
  COMPLETED
  NO_SHOW
}

enum MessageChannel {
  SMS
  WEB_PUSH // installed-PWA push (free); the push-first leg of a loyalty/nudge send
  // EMAIL - future seam, not implemented
}

enum PromotionKind {
  PERCENT_OFF // e.g. 20% off
  AMOUNT_OFF // e.g. $5 off
  FREE_ADDON // e.g. free hot towel with any cut
  EXTRA_PUNCHES // visits earn extra punches while the promo is live
}

//  Identity / tenancy 

model User {
  id            String    @id @default(cuid())
  email         String    @unique // login identity (global)
  passwordHash  String? // argon2id; null for social-only accounts
  googleId      String?   @unique // Google "sub"; set for Google sign-in
  appleId       String?   @unique // Apple "sub"; set for Sign in with Apple (native iOS)
  name          String
  // Session revocation: bumped on password change, which invalidates every
  // previously issued session token (tokens embed the version they were minted with).
  tokenVersion  Int       @default(0)
  // Platform operator. Gates the /admin portal. Set by hand (or the bootstrap
  // script) - never settable through any self-serve endpoint.
  isAdmin       Boolean   @default(false)
  // Explicit SMS attestation: the barber affirmed they will only add/text
  // clients who consented and that they're authorized to send on their behalf.
  // Captured at signup (form) or first onboarding step (Google path). The legal
  // basis for ChairBack sending SMS on the shop's behalf.
  smsAttestedAt DateTime?
  // First-run welcome tour: stamped the first time the barber finishes (or
  // skips) the dashboard welcome carousel. null = never seen, so the tour
  // auto-opens once. Replaying it from the account card does NOT clear this.
  welcomeSeenAt DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  shops Shop[] @relation("ShopOwner") // one today; FK clean for N later

  passwordResetTokens PasswordResetToken[]
  // Barber/manager devices registered for native push (dashboard app).
  pushSubscriptions   PushSubscription[]
}

// One-shot forgot-password tokens. Only the sha256 of the token is stored - the
// raw value exists solely inside the emailed link, so a DB leak can't reset
// anyone's password. Rows are short-lived (30 min expiry, deleted when a newer
// request supersedes them) and single-use (usedAt stamped atomically on redeem).
//
// Non-tenant table (keyed to User, the global login identity): RLS is ENABLED
// with NO policy in the migration - deny-all for the Supabase data API roles,
// while the postgres owner the app connects as bypasses RLS. Matches the
// 20260609000000 non-tenant lockdown pattern. NOT force-RLS.
model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String    @unique // sha256 hex of the emailed token; never the raw value
  expiresAt DateTime
  usedAt    DateTime? // stamped on redeem; non-null = spent, can never be replayed
  createdAt DateTime  @default(now())

  @@index([userId])
}

model Shop {
  id                  String  @id @default(cuid())
  ownerId             String
  owner               User    @relation("ShopOwner", fields: [ownerId], references: [id])
  name                String // appears in SMS body
  timezone            String  @default("America/New_York")
  // Optional: a shop may have no external booking link (not on Acuity/Square/etc).
  // When null, "Book" CTAs fall back to the client's ChairBack rewards page and
  // the public page shows the "request a time" form instead of a Book button.
  bookingUrl          String?
  // DEPRECATED single-reward config: superseded by the Reward table (each shop
  // designs its own menu). Columns kept so the previously deployed API keeps
  // working through the migration window; no current code reads them.
  rewardThreshold     Int     @default(10)
  rewardLabel         String  @default("Free Cut")
  // Base loyalty earn rate: punches per completed visit. Service-specific
  // EarnRule rows override it for matching services.
  punchesPerVisit     Int     @default(1)
  nudgeBufferDays     Int     @default(7)
  dailySendCap        Int     @default(50)
  // Transactional loyalty SMS to CLIENTS: a text the moment a completed visit
  // earns punches, or a reward is redeemed ("You earned 1 punch - 4/10 toward a
  // Free Cut"). Off by default - opt-in per shop. Independent of the marketing
  // nudge/promo sends: still gated by client SMS consent + quiet hours, but NOT
  // counted against dailySendCap (it's triggered by a real visit, not a blast).
  loyaltyTextsEnabled Boolean @default(false)
  // Win-back ("Growth Agent") sends: a warmer "it's been a while" SMS to clients
  // who are DEEPLY lapsed (well past their own cadence), distinct from the
  // regular just-overdue rebooking nudge. Off by default - opt-in per shop, same
  // as loyaltyTextsEnabled. Marketing cost, so it DOES count against dailySendCap.
  // See engines/winback.ts.
  winbackTextsEnabled Boolean @default(false)
  smsTemplate         String? // custom nudge copy; null = built-in default. Placeholders: {firstName} {shop} {bookingUrl} {rewardsUrl}
  // Custom win-back copy; null = built-in default. Same placeholders as smsTemplate.
  winbackTemplate     String?
  logoUrl             String? // shop logo shown on the rewards + public pages (white-label)
  accentColor         String? // hex accent (e.g. "#D4AF37"); null = the theme's accent
  // Rebooking countdown: target window (days) for a client to rebook after their
  // last visit. Drives the urgency timer on the rewards page. Default 14 (<2 wks).
  rebookWindowDays    Int     @default(14)
  plan                String  @default("free") // "free" | "pro" | "pro_ai"; kept in sync by the Stripe webhook
  // Vertical (INDUSTRIES key in packages/config). Flavors onboarding defaults
  // and copy only - the data model is service-business generic.
  industry            String  @default("barber")

  // Billing (Stripe). Access = active/trialing/past_due subscription OR an
  // unexpired trial. When the STRIPE_* env vars are absent, billing is
  // disabled and every shop has full access (the pre-revenue behavior).
  stripeCustomerId     String?   @unique
  stripeSubscriptionId String?
  subscriptionStatus   String    @default("none") // mirrors Stripe subscription.status
  trialEndsAt          DateTime?
  // Comped full access (friends / testers / partners). When true, the shop has
  // Premium regardless of Stripe - independent of trial/subscription, survives
  // Stripe going live, and is excluded from paying-revenue counts. Operator-only.
  compAccess           Boolean   @default(false)
  // Trial-expiry reminder emails: the highest stage already sent (0 = none,
  // 1 = "a week left", 2 = "ends tomorrow", 3 = "trial ended"). Monotonic - the
  // sweep only ever advances it (compare-and-set BEFORE sending), so each stage
  // emails at most once no matter how many times the daily job runs. See
  // engines/trialReminder.ts.
  trialReminderStage   Int       @default(0)

  // Public shop page (/s/[slug]) - each barber's own mini-site.
  slug              String?  @unique // URL handle; backfilled from name
  publicPageEnabled Boolean  @default(true)
  theme             String   @default("classic") // PAGE_THEMES key
  bio               String? // short intro shown on the hero
  heroImageUrl      String? // wide banner image
  instagramHandle   String? // without the @
  hoursText         String? // freeform hours ("Mon-Fri 9-6 ...")
  galleryUrls       String[] @default([]) // legacy: bare photo URLs (superseded by galleryItems)
  // Gallery photos with optional per-photo captions: [{ url, caption? }, ...].
  // Migrated from galleryUrls; galleryUrls is kept for one release as a safety net.
  galleryItems      Json     @default("[]")
  // Per-shop styling so each page looks like THEIR shop (see PAGE_FONTS /
  // LAYOUT_STYLES / PAGE_SECTIONS in config). All optional; null = the default.
  fontKey           String? // PAGE_FONTS key (typography pairing)
  layoutStyle       String? // LAYOUT_STYLES key (corner/button shape)
  sectionOrder      String[] @default([]) // PAGE_SECTIONS keys in render order; [] = default order

  // Client rewards page (/r/[magicToken]) content control. The rewards page
  // already inherits the shop's theme/font/shape (see PAGE_* fields above); these
  // let the barber tailor what it SAYS and SHOWS.
  // rewardsWelcome: optional short greeting at the top; null = no custom line.
  // rewardsSections: visible REWARDS_SECTIONS keys; [] = show all (the default).
  // The punch balance + SMS consent card are always shown (not in this list).
  rewardsWelcome  String?
  rewardsSections String[] @default([])

  // Appointment requests (lead form on the public page). When takesRequests is
  // on, /s/[slug] shows a "Request an appointment" form instead of the booking
  // link - for barbers with no online booking. notifyPhone (E.164) is texted on
  // each new request; null = no SMS, the lead only lands in the dashboard inbox.
  takesRequests Boolean @default(false)
  notifyPhone   String? // E.164; barber's number for lead-request texts. null = inbox only

  // Waitlist: when on, the public booking page offers "Join the waitlist" (a
  // standing button + when a day is fully booked) and entries land in the
  // barber's dashboard. Off by default so existing shops are unchanged. Reuses
  // notifyPhone for the new-entry SMS alert.
  waitlistEnabled Boolean @default(false)
  // "A slot just opened" auto-notify: when a native appointment is CANCELED,
  // matching waitlisters get a push/email nudge that the freed slot is open. The
  // BARBER always gets an alert (their own number/device) when the waitlist is
  // on; this toggle controls the CUSTOMER-facing blast (outbound to leads), so
  // it's off by default and separate from waitlistEnabled. See engines/slotOpened.
  slotOpenedTextsEnabled Boolean @default(false)
  // Automatic appointment reminder PUSHES (24h + 2h before start), per tier.
  // Deliberately default TRUE (unlike every other toggle): reminders are
  // expected table-stakes behavior, push is free/uncapped, and the column
  // default backfills every existing shop ON. Barbers who want neither flip
  // both off in booking settings. SMS/email reminders are separate and keep
  // their own gates. See engines/pushReminders.ts.
  pushReminder24hEnabled Boolean @default(true)
  pushReminder2hEnabled  Boolean @default(true)

  // Request-before-booking: when on, a public NATIVE booking lands as PENDING
  // (holds the slot, no confirmation sent) until the barber approves it in the
  // agenda. Off by default so existing shops are unchanged. Native-only.
  requireBookingApproval Boolean @default(false)

  // AI receptionist (paid add-on). The master toggle is receptionistEnabled;
  // the feature additionally requires bookingMode=native, active base billing,
  // the add-on entitlement (receptionistCompAccess OR an active add-on
  // subscription), an accepted liability acknowledgment, and ANTHROPIC_API_KEY
  // set - all evaluated in ONE place (apps/api/src/receptionist/config.ts).
  receptionistEnabled Boolean @default(false)
  // Optional voice knob injected into the prompt file's {{TONE}} placeholder
  // (e.g. "relaxed & friendly"); null = the prompt's default voice.
  receptionistTone String?
  // Add-on billing (mirrors subscriptionStatus for the $40/mo receptionist
  // price). "none" until the shop subscribes; kept in sync by the Stripe
  // webhook. receptionistCompAccess = comped entitlement (pilot shops).
  receptionistSubscriptionStatus String  @default("none")
  receptionistCompAccess         Boolean @default(false)
  // Liability click-through: the barber acknowledged the AI can make scheduling
  // mistakes (double-bookings, misses) and ChairBack isn't liable. Stamped by
  // the settings route when receptionistEnabled is first turned on; enabling is
  // REJECTED without it. null = never accepted.
  receptionistTermsAcceptedAt DateTime?

  // per-shop webhook routing (the body has no account id, so the URL path routes)
  webhookSecret    String   @unique // 32-byte random, used in the webhook URL path
  acuityWebhookIds String[] @default([]) // subscription ids returned by Acuity (teardown)

  // Native booking engine. bookingMode picks the ONE active source (see enum);
  // default `link` so every existing shop keeps its bookingUrl behavior until the
  // barber explicitly switches to `native`. The bounds below shape the public
  // slot picker - all interpreted in this shop's `timezone`.
  bookingMode      BookingMode @default(link)
  bookingLeadHours Int         @default(2) // earliest bookable slot = now + this many hours
  bookingMaxDays   Int         @default(60) // how far ahead a customer may book
  bookingBufferMin Int         @default(0) // turnover gap added after each appointment

  // Customer payments (Stripe Connect Express). All default to "off"/absent so
  // existing shops are unchanged until the barber connects + turns payments on.
  stripeConnectAccountId String?      @unique // the shop's acct_ (NOT stripeCustomerId)
  connectChargesEnabled  Boolean      @default(false) // mirrors account.charges_enabled
  payoutsEnabled         Boolean      @default(false) // mirrors account.payouts_enabled
  paymentsMode           PaymentsMode @default(off)
  platformFeeBps         Int          @default(0) // platform cut, basis points (0 = barber keeps 100%)
  // Per-shop cancellation policy. A customer can always cancel; if they cancel
  // INSIDE this window (hours before the appointment), cancelFeeBps of the price
  // is kept as a fee (rest refunded). 0 hours = no fee window (always full refund).
  cancelWindowHours      Int          @default(0)
  cancelFeeBps           Int          @default(0) // 10000 bps = 100% (no refund inside window)

  // Fee-free "pay the barber DIRECTLY" handles (Zelle / Venmo / Cash App). These
  // are DISPLAY-ONLY: shown on the booking confirmation so a customer can pay the
  // barber bank-to-bank with 0% fee. ChairBack does NOT process, verify, or
  // reconcile them — Zelle/Venmo/Cash App have no third-party platform API, so the
  // barber confirms payment themselves. Independent of the Stripe paymentsMode
  // flow above; a shop can offer card (Stripe) AND/OR pay-direct.
  payDirectEnabled Boolean @default(false)
  payDirectZelle   String? // Zelle email or phone number
  payDirectVenmo   String? // Venmo @handle (without the leading @)
  payDirectCashApp String? // Cash App $cashtag (without the leading $)
  payDirectNote    String? // freeform instruction, e.g. "Zelle or cash on arrival"

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  acuity              AcuityConnection?
  square              SquareConnection?
  clients             Client[]
  visits              Visit[]
  ledger              PunchLedger[]
  nudges              Nudge[]
  rewards             Reward[]
  earnRules           EarnRule[]
  cardTypes           CardType[]
  cardGrants          CardGrant[]
  promotions          Promotion[]
  promoUses           PromotionRedemption[]
  appointmentRequests AppointmentRequest[]
  waitlist            WaitlistEntry[]
  reviews             Review[]
  receptionistConversations ReceptionistConversation[]
  receptionistMessages      ReceptionistMessage[]
  pushSubscriptions   PushSubscription[]
  walletPasses        WalletPassRegistration[]

  // Native booking engine relations
  staff                  Staff[]
  services               Service[]
  serviceStaff           ServiceStaff[]
  availabilityRules      AvailabilityRule[]
  availabilityExceptions AvailabilityException[]
  appointments           Appointment[]
  recurringSeries        RecurringSeries[]
  serviceAddOns          ServiceAddOn[]
  targetedSlots          TargetedSlot[]
  payments               Payment[]

  @@index([ownerId])
}

// A shop-designed promotion ("Spring special: 20% off weekday cuts"). Live =
// active && startsAt <= now && (endsAt null || endsAt > now). Shows on the
// client rewards page; can be blasted by SMS; EXTRA_PUNCHES kinds boost earning
// while live.
model Promotion {
  id           String        @id @default(cuid())
  shopId       String
  shop         Shop          @relation(fields: [shopId], references: [id], onDelete: Cascade)
  kind         PromotionKind
  title        String // "Spring Special"
  description  String? // "20% off any weekday cut"
  code         String? // optional walk-in code the client shows ("SPRING20")
  percentOff   Int? // PERCENT_OFF
  amountOff    Decimal?      @db.Decimal(10, 2) // AMOUNT_OFF (dollars)
  extraPunches Int? // EXTRA_PUNCHES: extra per completed visit while live
  startsAt     DateTime      @default(now())
  endsAt       DateTime? // null = runs until paused
  active       Boolean       @default(true)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  redemptions PromotionRedemption[]
  nudges      Nudge[] // promo SMS blasts, for per-promo attribution

  @@index([shopId, active, startsAt])
}

// One client cashing in one promotion (barber records it at the chair).
model PromotionRedemption {
  id          String    @id @default(cuid())
  shopId      String
  shop        Shop      @relation(fields: [shopId], references: [id], onDelete: Cascade)
  promotionId String
  promotion   Promotion @relation(fields: [promotionId], references: [id], onDelete: Cascade)
  clientId    String
  client      Client    @relation(fields: [clientId], references: [id], onDelete: Cascade)
  redeemedAt  DateTime  @default(now())

  @@index([shopId, promotionId])
  @@index([shopId, clientId])
}

// A shop-designed reward on the loyalty menu ("5 punches = free beard lineup").
// Each shop curates as many as it wants; clients redeem against a specific one.
model Reward {
  id          String   @id @default(cuid())
  shopId      String
  shop        Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade)
  name        String // "Free Cut", "Free Beard Trim", "$10 Off Premium Package"
  description String? // optional detail shown under the name on the client page
  emoji       String? // small visual flair on the client page (e.g. "✂️")
  punchCost   Int // punches deducted when the barber redeems it
  // Which card's balance this reward draws from. NULL = the shop's default
  // card. Restrict (not SetNull): nulling on card delete would silently move
  // the reward onto the default card's balance - the delete endpoint refuses
  // instead ("archive the card").
  cardTypeId  String?
  cardType    CardType? @relation(fields: [cardTypeId], references: [id], onDelete: Restrict)
  active      Boolean  @default(true) // inactive = hidden from clients, kept for history
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  redemptions PunchLedger[]

  @@index([shopId, active])
  @@index([cardTypeId])
}

// Barber-designed punch card TYPE ("Haircut card", "Retwist card", "VIP").
// Each card type is its own balance: PunchLedger rows carry cardTypeId, and a
// NULL cardTypeId everywhere means the shop's classic/default card - existing
// shops keep working with zero backfill. A completed visit routes to the first
// active card (by sortOrder) whose serviceMatch term appears in the visit's
// serviceName; the barber can override at the chair. Exclusive cards are
// invite-only: only clients with a CardGrant earn/see them (auto-matching skips
// everyone else), which is how a barber builds a "VIP" card.
model CardType {
  id              String   @id @default(cuid())
  shopId          String
  shop            Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade)
  name            String // "VIP", "Retwist Card"
  description     String?
  emoji           String?
  accentColor     String? // "#RRGGBB" shown on the client page; null = shop accent
  serviceMatch    String[] @default([]) // substring terms vs Visit.serviceName (case-insensitive)
  punchesPerVisit Int      @default(1) // earn amount for visits routed here (EarnRule is default-card-only)
  exclusive       Boolean  @default(false) // invite-only: only granted clients earn/see it
  active          Boolean  @default(true) // inactive = archived; balances/history stay intact
  sortOrder       Int      @default(0) // routing priority: first match wins
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  ledger  PunchLedger[]
  rewards Reward[]
  grants  CardGrant[]

  @@index([shopId, active])
}

// Membership of one client in one exclusive card. Upserted when the barber
// invites a client (or override-punches their exclusive card - the punch IS
// the invite). Unique per (card, client) so granting is idempotent.
model CardGrant {
  id         String   @id @default(cuid())
  shopId     String
  shop       Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade)
  cardTypeId String
  cardType   CardType @relation(fields: [cardTypeId], references: [id], onDelete: Cascade)
  clientId   String
  client     Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())

  @@unique([cardTypeId, clientId])
  @@index([shopId, clientId])
}

// Service-specific earn override: a completed visit whose serviceName contains
// `serviceMatch` (case-insensitive) earns `punches` instead of the shop's base
// punchesPerVisit. First match by sortOrder wins. Applies to the DEFAULT card
// only - custom CardTypes carry their own flat punchesPerVisit.
model EarnRule {
  id           String   @id @default(cuid())
  shopId       String
  shop         Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade)
  serviceMatch String // substring matched against Visit.serviceName
  punches      Int
  active       Boolean  @default(true)
  sortOrder    Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([shopId, active])
}

// Secrets isolated in their own 1:1 model so plain Shop reads never load ciphertext.
model AcuityConnection {
  id              String    @id @default(cuid())
  shopId          String    @unique
  shop            Shop      @relation(fields: [shopId], references: [id], onDelete: Cascade)
  acuityAccountId String // from GET /me
  accessToken     String // AES-256-GCM encrypted
  refreshToken    String? // AES-256-GCM encrypted; may be absent
  scope           String    @default("api-v1")
  tokenExpiresAt  DateTime? // may be null if no expiry
  connectedAt     DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([acuityAccountId])
}

// Square Appointments connection. Mirrors AcuityConnection: one per shop, holds
// the OAuth tokens (encrypted) + the Square merchant/location ids. Distinct from
// Acuity in two ways the code must respect: (1) the refresh token is REQUIRED
// and long-lived (access token expires every ~30 days, so we refresh
// proactively), (2) bookings are scoped to a single Square LOCATION, so we pin
// one. Like AcuityConnection this is a secrets table looked up by shopId/
// merchantId (NOT a tenant-RLS table): ENABLE RLS only, no FORCE/policy/GRANT.
model SquareConnection {
  id               String   @id @default(cuid())
  shopId           String   @unique
  shop             Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade)
  squareMerchantId String // from the OAuth token response; webhook merchant_id -> shop
  squareLocationId String? // the chosen location; bookings are location-scoped
  accessToken      String // AES-256-GCM encrypted (expires ~30 days)
  refreshToken     String // AES-256-GCM encrypted; REQUIRED (long-lived, multi-use)
  scope            String   @default("APPOINTMENTS_READ APPOINTMENTS_ALL_READ CUSTOMERS_READ MERCHANT_PROFILE_READ")
  tokenExpiresAt   DateTime // from expires_at; drives the proactive refresh sweep
  revokedAt        DateTime? // set on oauth.authorization.revoked (seller disconnect)
  connectedAt      DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([squareMerchantId])
}

//  Tenant-owned domain (every table carries shopId)

// Self-reported visit cadence, captured as one tap at the customer's first app
// open (skippable). Internal RANK only; the customer-facing label/day-count live
// in CADENCE_OPTIONS (@chairback/config) so copy can change without a migration.
enum CadencePreference {
  WEEKLY // ~ every 7 days
  BIWEEKLY // ~ every 14 days
  EVERY_3_WEEKS // ~ every 21 days
  MONTHLY // ~ every 30 days
  OCCASIONAL // 6+ weeks / no fixed schedule
}

// Loyalty status tier. The enum is the internal RANK only; the display
// label/color (and per-shop overrides later) come from LOYALTY_TIERS in
// @chairback/config. Stamped by the loyalty engine from lifetime completed
// visits; null = not yet computed / below the first tier.
enum LoyaltyTier {
  BRONZE
  SILVER
  GOLD
}

model Client {
  id               String    @id @default(cuid())
  shopId           String
  shop             Shop      @relation(fields: [shopId], references: [id], onDelete: Cascade)
  acuityClientKey  String // normalized phone || email || anon slug
  firstName        String?
  lastName         String?
  phone            String? // E.164
  email            String?
  optedOut         Boolean   @default(false)
  // Why optedOut is set: "sms_stop" (client texted STOP - only the client can
  // reverse it, via START or their rewards page; the dashboard may NOT),
  // "client_self_serve" (rewards-page opt-out), "barber" (dashboard toggle),
  // or null (not opted out / legacy row from before this column existed).
  optOutSource     String?
  // SMS consent (TCPA). A client is textable only when optedOut == false AND
  // smsConsentAt != null. optedOut is the live STOP/START gate; smsConsentAt is
  // the proof-of-opt-in gate. New clients (e.g. synced from Acuity) have no
  // consent until it is granted, so they are NOT textable by default.
  smsConsentAt     DateTime? // when opt-in was captured; null = never consented
  smsConsentSource String? // "acuity_intake" | "barber_attest" | "manual" | "join_page"
  notes            String? // barber's private notes about the client
  // Soft origin label. "acuity" (default; also where Square-synced clients land
  // today since the Square ingest doesn't override it) | "manual" (dashboard
  // add / native booking) | "import" (CSV import).
  source           String    @default("acuity")
  magicToken       String    @unique // GLOBAL - rewards auth resolves without a shop

  // Soft-archive. A barber can hide a client they no longer want in their active
  // book (duplicate, one-off walk-in, moved away) WITHOUT destroying history -
  // archivedAt is set, never the row deleted. An archived client is excluded from
  // every "active" surface (clients list default, stats, leaderboard, at-risk, all
  // SMS sends) but is still reachable by id (detail page) so it can be un-archived.
  // Archive is sticky through Acuity re-sync: a new booking updates the row but
  // does NOT auto-unarchive (un-hiding is an explicit barber choice).
  archivedAt DateTime?

  // cadence (recomputed by the engine; null until >=2 completed visits)
  medianIntervalDays Int?
  lastVisitAt        DateTime?
  nextExpectedAt     DateTime?

  // Self-reported cadence captured at the customer's first app open (one tap,
  // skippable). COLD-START SEED ONLY: the engine prefers the computed
  // medianIntervalDays once the client clears NUDGE.minCompletedVisits; until
  // then this seeds nextExpectedAt so a brand-new client gets a working rebook
  // countdown on day one. null = never asked or skipped. Days via CADENCE_OPTIONS.
  preferredCadence CadencePreference?
  // Loyalty status tier, stamped by the loyalty engine from lifetime completed
  // visits against LOYALTY_TIERS. null = not yet computed / below the first tier.
  loyaltyTier      LoyaltyTier?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  visits              Visit[]
  ledger              PunchLedger[]
  nudges              Nudge[]
  promoUses           PromotionRedemption[]
  appointments        Appointment[]
  recurringSeries     RecurringSeries[]
  pushSubscriptions   PushSubscription[]
  cardGrants          CardGrant[]
  walletRegistrations WalletPassRegistration[]
  receptionistConversations ReceptionistConversation[]

  @@unique([shopId, acuityClientKey]) // tenant-scoped identity + idempotent upsert
  @@index([shopId])
  @@index([shopId, lastVisitAt])
  @@index([shopId, archivedAt]) // default list/stats filter on (shop, not archived)
  @@index([phone]) // inbound Twilio STOP/START + public resolve-by-phone (cross-tenant phone lookup)
}

// A lead submitted from the public shop page's "Request an appointment" form.
// Created via the UNauthenticated public route (resolved by slug), so the insert
// runs as the connection owner and bypasses FORCE RLS - the same path the public
// rewards/Twilio writes use. The barber reads/updates these through forShop()
// (RLS-enforced). Not a booking - just a contact the barber follows up on.
model AppointmentRequest {
  id            String  @id @default(cuid())
  shopId        String
  shop          Shop    @relation(fields: [shopId], references: [id], onDelete: Cascade)
  firstName     String
  lastName      String?
  phone         String? // E.164 when parseable, else raw input
  email         String?
  message       String? // freeform note from the client
  preferredTime String? // freeform ("weekday evenings", "Sat morning")
  status        String  @default("NEW") // "NEW" | "CONTACTED" | "CLOSED"

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([shopId, status])
  @@index([shopId, createdAt])
}

// A customer waiting for a spot to open. Created from the public booking page
// (a standing "Join the waitlist" button, or when a day is fully booked), then
// worked by the barber from the dashboard. Same public-write trust model as
// AppointmentRequest (created as the connection owner, read/updated via forShop).
// serviceId/staffId are captured when the join comes from a full day (so the
// barber knows exactly what they want) and are reserved for a later
// auto-notify-on-cancel fast-follow that matches a freed slot to the queue.
model WaitlistEntry {
  id            String   @id @default(cuid())
  shopId        String
  shop          Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade)
  firstName     String
  lastName      String?
  phone         String? // E.164 when parseable, else raw input
  email         String?
  serviceId     String? // set when joined from a full day; null for a standing join
  staffId       String? // "" / null = any provider
  preferredTime String? // freeform ("Sat morning") for standing joins
  note          String? // freeform note from the client
  status        String    @default("WAITING") // WAITING | CONTACTED | BOOKED | REMOVED
  notifiedAt    DateTime? // reserved for the auto-notify fast-follow (dedupe stamp)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([shopId, status, createdAt])
}

// Customer review submitted from the public shop page. Same trust model as
// AppointmentRequest: created via the UNauthenticated public route (resolved by
// slug, runs as the connection owner, bypasses FORCE RLS), then the barber
// reads/moderates through forShop() (RLS-enforced). Approve-first: a review is
// PENDING until the barber approves it; only APPROVED reviews are ever returned
// on the public page. authorName is optional (blank -> shown as "Anonymous").
model Review {
  id         String  @id @default(cuid())
  shopId     String
  shop       Shop    @relation(fields: [shopId], references: [id], onDelete: Cascade)
  rating     Int // 1-5 stars (validated at the API boundary)
  body       String? // freeform review text; optional (a rating alone is allowed)
  authorName String? // optional display name; null/blank -> "Anonymous"
  status     String  @default("PENDING") // "PENDING" | "APPROVED" | "HIDDEN"

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([shopId, status])
  @@index([shopId, createdAt])
}

model Visit {
  id                  String      @id @default(cuid())
  shopId              String
  shop                Shop        @relation(fields: [shopId], references: [id], onDelete: Cascade)
  clientId            String
  client              Client      @relation(fields: [clientId], references: [id], onDelete: Cascade)
  acuityAppointmentId String // unique only WITHIN an account, so must be composite with shopId
  status              VisitStatus
  scheduledAt         DateTime
  endAt               DateTime? // start + duration; drives COMPLETED promotion
  completedAt         DateTime?
  canceledAt          DateTime?
  noShow              Boolean     @default(false)
  price               Decimal?    @db.Decimal(10, 2)
  serviceName         String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  punch       PunchLedger?
  appointment Appointment? // the native booking this Visit was promoted from (if any)

  @@unique([shopId, acuityAppointmentId]) // IDEMPOTENCY (per shop): webhook re-delivery + backfill safe
  @@index([shopId, clientId, scheduledAt]) // cadence + future-booking checks
  @@index([shopId, clientId, createdAt]) // attribution booking lookup (createdAt window)
  @@index([status, endAt]) // promotion scan
  @@index([shopId, status, scheduledAt]) // insights/trends/avg-ticket + activity feed by (shop, status, date)
}

model PunchLedger {
  id              String   @id @default(cuid())
  shopId          String
  shop            Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade)
  clientId        String
  client          Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  visitId         String?  @unique // one EARN per visit; redemptions use null (Postgres allows many NULLs)
  visit           Visit?   @relation(fields: [visitId], references: [id], onDelete: Cascade)
  // Which menu reward a redemption bought. SetNull keeps the ledger history
  // intact if the barber later deletes the reward (note still has the name).
  rewardId        String?
  reward          Reward?  @relation(fields: [rewardId], references: [id], onDelete: SetNull)
  // Which punch card this entry belongs to. NULL = the shop's default card;
  // balances are per (shopId, clientId, cardTypeId). Restrict (not SetNull):
  // nulling on card delete would silently merge that card's balance into the
  // default card - a balance mutation via a delete button. The card delete
  // endpoint refuses while ledger rows exist ("archive the card" instead).
  cardTypeId      String?
  cardType        CardType? @relation(fields: [cardTypeId], references: [id], onDelete: Restrict)
  punchesEarned   Int      @default(0)
  punchesRedeemed Int      @default(0)
  runningBalance  Int // per-card snapshot after this entry (card = this row's cardTypeId)
  note            String?
  createdAt       DateTime @default(now())

  // Barber-correctable ledger. The ledger stays append-only - the barber never
  // deletes a row. "Undo a punch" writes a NEW offsetting correction row and
  // stamps reversedAt on the original, so the balance self-heals and the full
  // history (including what was undone) is preserved for audit.
  //
  // reversedAt: set on an ORIGINAL row once a correction has reversed it. A
  // reversed row no longer counts toward "is this still undoable" - it can't be
  // reversed twice. The aggregate balance still sums it (it's offset by its
  // correction), so the snapshot math is unchanged.
  reversedAt   DateTime?
  // reversalOf: set on a CORRECTION row, pointing at the original it reverses.
  // Self-relation; SetNull so deleting history (shop teardown cascades) can't
  // dangle. A correction's note carries the human reason ("undo: visit").
  reversalOfId String?
  reversalOf   PunchLedger?  @relation("LedgerReversal", fields: [reversalOfId], references: [id], onDelete: SetNull)
  reversedBy   PunchLedger[] @relation("LedgerReversal")

  // correctionOf: set on the FRESH re-granted earn that "edit count" writes after
  // reversing the original (adjustLedgerEntry). It points at the correction row of
  // that edit, so a later visit claw-back (ingest) can find and remove this regrant
  // too. Without it, canceling a visit whose punch was edited would delete the
  // original earn + its correction but ORPHAN this regrant, overstating the balance.
  // Distinct from reversalOf so this regrant is NOT mislabeled a correction in the
  // ledger UI or excluded from redemption/earn counts. SetNull mirrors reversalOf.
  correctionOfId String?
  correctionOf   PunchLedger?  @relation("LedgerCorrection", fields: [correctionOfId], references: [id], onDelete: SetNull)
  correctedBy    PunchLedger[] @relation("LedgerCorrection")

  @@index([shopId, clientId])
  @@index([rewardId])
  @@index([cardTypeId])
  @@index([reversalOfId])
  @@index([correctionOfId])
}

model Nudge {
  id                  String         @id @default(cuid())
  shopId              String
  shop                Shop           @relation(fields: [shopId], references: [id], onDelete: Cascade)
  clientId            String
  client              Client         @relation(fields: [clientId], references: [id], onDelete: Cascade)
  channel             MessageChannel @default(SMS)
  status              NudgeStatus    @default(PENDING)
  // What kind of outbound text this was: "nudge" (rebooking), "promo" (promotion
  // blast), or "loyalty" (transactional earn/redeem confirmation). Nudge + promo
  // count against the shop's daily send cap; loyalty does NOT (it's triggered by
  // a real visit/redemption, not a blast) - see services/loyaltyNotify.ts.
  kind                String         @default("nudge")
  // Set on promo blasts so rebookings can be attributed to a SPECIFIC promo.
  promotionId         String?
  promotion           Promotion?     @relation(fields: [promotionId], references: [id], onDelete: SetNull)
  // Set on appointment-scoped sends (kind "checkin_nudge" / "checkin_nudge_reply"):
  // the barber's "come early" push + the client's one-tap reply. The per-
  // appointment nudge rate limit (max 2) counts rows by this FK. SetNull keeps
  // the audit row if the appointment is ever deleted.
  appointmentId       String?
  appointment         Appointment?   @relation(fields: [appointmentId], references: [id], onDelete: SetNull)
  body                String?
  messageSid          String?
  failedReason        String?
  sentAt              DateTime?
  resultedInBookingAt DateTime? // attribution
  resultedVisitId     String?
  createdAt           DateTime       @default(now())

  @@index([shopId, clientId, createdAt]) // "no nudge in 21d" + attribution lookback
  @@index([status, createdAt]) // daily send-cap count
  @@index([status, sentAt]) // hourly attribution fetch (SENT nudges by sentAt window)
  @@index([shopId, resultedInBookingAt]) // /stats + /trends "rebookings recovered this month"
  @@index([promotionId])
  @@index([shopId, kind, createdAt]) // monthly SMS quota count + receptionist reply caps
  @@index([appointmentId, kind]) // per-appointment nudge rate limit
}

// How a push subscription is delivered. One table holds both transports so the
// send path treats every device uniformly:
//   web  = browser/PWA Web Push (VAPID; endpoint + p256dh + auth).
//   expo = native iOS/Android app via Expo's push service (expoPushToken).
enum PushKind {
  web
  expo
}

// A push subscription for ONE device of one identity - EITHER a client (the
// customer rewards page/app) OR a user (the barber/manager dashboard app).
// Exactly one of clientId/userId is set; the API stamps it server-side. The OS
// permission grant + this row ARE the push consent, independent of SMS consent
// (smsConsentAt/optedOut), so a client who replied STOP to texts but installed
// and allowed notifications is still push-reachable (and still no SMS).
//
// Tenant-owned (shopId, FORCE RLS) like the rest. Client rows are created on
// the PUBLIC rewards route (resolved by the global magicToken, runs as the
// connection owner, bypasses RLS - same trust model as the rewards opt-in /
// AppointmentRequest / Review writes); the client send path reads them through
// forShop() (RLS-enforced). USER rows are created on the authenticated
// dashboard route and read via runAsOwner: a manager's device serves every
// shop they own, so the lookup is user-keyed, not shop-scoped - shopId records
// the shop active at registration. shopId/userId are always derived from the
// resolved client/session, never from the request body.
model PushSubscription {
  id            String   @id @default(cuid())
  shopId        String
  shop          Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade)
  // CUSTOMER transport: the client this device belongs to. Null for barber rows.
  clientId      String?
  client        Client?  @relation(fields: [clientId], references: [id], onDelete: Cascade)
  // BARBER transport: the owner/manager this device belongs to. Null for client rows.
  userId        String?
  user          User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  kind          PushKind @default(web)
  // WEB transport: the push service endpoint URL (FCM/Mozilla/Apple) + the keys
  // used to encrypt the payload. Null for expo rows. endpoint is unique so a
  // re-subscribe on the same browser upserts rather than duplicating.
  endpoint      String?  @unique
  p256dh        String? // client public key (base64url) for payload encryption
  auth          String? // client auth secret (base64url) for payload encryption
  // EXPO transport: the Expo push token (ExponentPushToken[...]). Null for web
  // rows. Unique so re-registering the same device upserts.
  expoPushToken String?  @unique
  userAgent     String? // captured at subscribe time, for debugging/pruning
  // Dead-subscription pruning: bumped on a transient send error, reset on success.
  // A gone receipt (web 404/410, or an expo DeviceNotRegistered) deletes the row.
  failureCount  Int      @default(0)
  createdAt     DateTime @default(now())
  lastSeenAt    DateTime @default(now()) // refreshed on re-subscribe + successful send

  @@index([shopId, clientId]) // the send-path lookup ("subs for this client")
  @@index([userId]) // the barber send-path lookup ("devices of this user")
}

// One iOS device registered for auto-updates of one client's Apple Wallet punch
// card (Apple's PassKit Web Service protocol: the device calls our /api/wallet
// v1 endpoints). deviceLibraryIdentifier is Apple's opaque per-device id;
// pushToken is the PASS-update APNs token (a different token/topic than app
// push - pokes go out signed with the Pass Type ID certificate). Tenant-owned
// via shopId (FORCE RLS home) like PushSubscription; rows are written by the
// public wallet routes via runAsOwner - the device authenticates with the
// pass's authenticationToken, an HMAC of the client id (stateless, derived
// from SESSION_SECRET), the same trust model as the magicToken writes.
model WalletPassRegistration {
  id                      String   @id @default(cuid())
  shopId                  String
  shop                    Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade)
  clientId                String
  client                  Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  deviceLibraryIdentifier String
  pushToken               String
  createdAt               DateTime @default(now())

  // A device registers a given pass once; re-registering refreshes the token.
  @@unique([deviceLibraryIdentifier, clientId])
  @@index([clientId]) // the poke path ("devices holding this client's pass")
  @@index([shopId])
}

//  Native booking engine (only used when Shop.bookingMode == native)

// A barber/chair within a shop. Multi-staff from the start: services,
// availability, and appointments all hang off a Staff, and the customer picks
// one before a slot. Soft-deleted (active=false) so historical appointments keep
// a valid FK. userId optionally links a single-barber shop's owner User.
model Staff {
  id        String   @id @default(cuid())
  shopId    String
  shop      Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade)
  name      String
  bio       String?
  imageUrl  String? // http(s) only (same boundary guard as shop branding)
  active    Boolean  @default(true)
  sortOrder Int      @default(0)
  userId    String? // optional link to the owning User (single-barber shops)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  services          ServiceStaff[]
  availabilityRules AvailabilityRule[]
  exceptions        AvailabilityException[]
  appointments      Appointment[]
  recurringSeries   RecurringSeries[]
  targetedSlots     TargetedSlot[]

  @@index([shopId, active])
}

// A bookable service (haircut, beard trim) with a duration that drives the slot
// step and a display price. `name` is copied onto the promoted Visit.serviceName,
// so the existing EarnRule substring matching keeps working unchanged.
model Service {
  id             String   @id @default(cuid())
  shopId         String
  shop           Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade)
  name           String
  description    String?
  durationMin    Int // length of the appointment (drives the slot step)
  price          Decimal? @db.Decimal(10, 2) // base/display price (no payment capture yet)
  // Per-weekday price overrides: a JSON map of shop-local weekday (0=Sun..6=Sat,
  // as string keys) to the price charged that day, e.g. {"0": 55} for a Sunday
  // premium. Only days that differ from `price` need an entry; any weekday absent
  // uses the base price. The customer is shown the effective price for the date
  // they pick (so a Sunday surcharge is never a surprise), and it's snapshotted
  // onto Appointment.priceAtBooking. See engines/pricing.ts (effectivePriceForDate).
  priceOverrides Json     @default("{}")
  // Per-weekday DURATION overrides, the same shape/semantics as priceOverrides:
  // {"5": 20} = Friday cuts take 20 min. Drives the slot grid for that day (a
  // Friday service consumes a 20-min block) and the appointment's endsAt, which
  // is the duration snapshot - editing this later never rewrites a booked row.
  // See engines/pricing.ts (effectiveDurationForDate).
  durationOverrides Json  @default("{}")
  active         Boolean  @default(true)
  sortOrder      Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  staff           ServiceStaff[]
  appointments    Appointment[]
  recurringSeries RecurringSeries[]
  addOns          ServiceAddOn[]
  targetedSlots   TargetedSlot[]

  @@index([shopId, active])
}

// An optional extra a customer can tack onto a service at booking (e.g. "+ beard
// trim", "+ hot towel"). Adds its durationMin to the appointment length and its
// price to the total. Shop-wide by default (serviceId null = offered on every
// service); scope to one service by setting serviceId. The CHOSEN add-ons are
// snapshotted onto Appointment.addOns at booking time (name/duration/price), so
// editing or deleting an add-on later never rewrites a past appointment.
model ServiceAddOn {
  id          String   @id @default(cuid())
  shopId      String
  shop        Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade)
  // null = available on ALL services; set = only offered with that one service.
  serviceId   String?
  service     Service? @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  name        String
  durationMin Int      @default(0) // extra minutes added to the appointment
  price       Decimal? @db.Decimal(10, 2) // extra charge added to the total
  active      Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([shopId, active])
  @@index([shopId, serviceId])
}

// Which staff offer which service (explicit join, multi-staff). shopId is
// denormalized so RLS is uniform across every booking table.
model ServiceStaff {
  id        String  @id @default(cuid())
  shopId    String
  shop      Shop    @relation(fields: [shopId], references: [id], onDelete: Cascade)
  serviceId String
  service   Service @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  staffId   String
  staff     Staff   @relation(fields: [staffId], references: [id], onDelete: Cascade)

  @@unique([serviceId, staffId])
  @@index([shopId])
  @@index([staffId])
}

// Recurring weekly availability for a staff member. Stored as LOCAL wall-clock
// minutes from midnight in the SHOP's timezone (not instants) so a "9-5" shift
// stays correct across DST - the concrete UTC instant is computed per date.
// weekday is 0=Sun..6=Sat (JS getDay). Multiple rows per (staff, weekday) model
// split shifts (e.g. a lunch gap).
model AvailabilityRule {
  id        String   @id @default(cuid())
  shopId    String
  shop      Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade)
  staffId   String
  staff     Staff    @relation(fields: [staffId], references: [id], onDelete: Cascade)
  weekday   Int // 0-6 (Sun-Sat), in shop-local time
  startMin  Int // minutes from local midnight, inclusive (e.g. 540 = 09:00)
  endMin    Int // minutes from local midnight, exclusive (e.g. 1020 = 17:00)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([shopId, staffId, weekday])
}

// A one-off override on a staff member's calendar. isBlock=true subtracts time
// (vacation, a day off, a lunch break on a specific date); isBlock=false adds a
// one-off open window (e.g. an extra Saturday). Stored as concrete UTC instants.
model AvailabilityException {
  id        String   @id @default(cuid())
  shopId    String
  shop      Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade)
  staffId   String
  staff     Staff    @relation(fields: [staffId], references: [id], onDelete: Cascade)
  startsAt  DateTime
  endsAt    DateTime
  isBlock   Boolean  @default(true)
  reason    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([shopId, staffId, startsAt])
}

// A barber-published ONE-OFF bookable slot with its own time/duration/price,
// under a parent service ("two retwist slots this week at a special price").
// Clients see it in the picker under that service, badged, at slot.price.
//
// Capacity is exactly ONE: booking claims bookedAppointmentId with a
// conditional update inside the SAME transaction as the shared booking guard,
// so two simultaneous bookings can't both win. While ACTIVE and UNBOOKED the
// slot also BLOCKS normal bookings over its span - enforced inside
// lockStaffAndAssertSlotFree (the one source of truth), so every write path
// (public, dashboard, recurring, receptionist) respects it with no extra code.
// Once booked, the created Appointment row does the blocking instead (the
// claimed slot stops matching the guard's unbooked predicate - no double
// count). A canceled targeted-slot appointment does NOT reopen the slot (the
// barber recreates one deliberately; auto-relisting a promo price is wrong).
//
// Deliberately allowed OUTSIDE availability rules (only lead-time checked):
// publishing a late-night special the normal grid would never offer is the
// point. Recurrence is materialized at creation (one row per week, same
// shop-local wall time via zonedWallTimeToUtc) - each row is independently
// bookable/deletable; no open-ended recurrence in v1.
model TargetedSlot {
  id          String   @id @default(cuid())
  shopId      String
  shop        Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade)
  staffId     String
  staff       Staff    @relation(fields: [staffId], references: [id], onDelete: Cascade)
  // The parent category the slot is listed under.
  serviceId   String
  service     Service  @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  label       String? // "Late night retwist", "Model rate"
  startsAt    DateTime
  durationMin Int
  price       Decimal  @db.Decimal(10, 2)
  active      Boolean  @default(true) // false = deactivated by the barber (unbooked only)
  // The winning booking. Unique = the capacity-1 claim; SetNull keeps the slot
  // row (as a consumed record) if the appointment is ever hard-deleted.
  bookedAppointmentId String?      @unique
  bookedAppointment   Appointment? @relation(fields: [bookedAppointmentId], references: [id], onDelete: SetNull)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([shopId, staffId, startsAt]) // guard overlap + barber list
  @@index([shopId, serviceId, startsAt]) // public picker per service
}

// A native booking. A future hold until its time passes (or the barber marks it
// done), when promoteFulfilledAppointments creates a COMPLETED Visit
// (acuityAppointmentId = "booking:{id}") and runs the SAME earn+cadence+loyalty
// pipeline as Acuity/manual visits. clientId may be null briefly if the Client
// upsert is decoupled, but is normally set at booking time. manageToken is the
// cancel/reschedule auth (like Client.magicToken). visitId back-points at the
// promoted Visit so cancel/no-show claw-back can find it.
model Appointment {
  id                 String            @id @default(cuid())
  shopId             String
  shop               Shop              @relation(fields: [shopId], references: [id], onDelete: Cascade)
  staffId            String
  staff              Staff             @relation(fields: [staffId], references: [id], onDelete: Restrict)
  serviceId          String
  service            Service           @relation(fields: [serviceId], references: [id], onDelete: Restrict)
  clientId           String?
  client             Client?           @relation(fields: [clientId], references: [id], onDelete: SetNull)
  // What the booker typed (kept even if the Client row is later archived/merged).
  firstName          String
  lastName           String?
  phone              String? // E.164 when parseable
  email              String?
  status             AppointmentStatus @default(BOOKED)
  startsAt           DateTime // UTC instant
  endsAt             DateTime // startsAt + service.durationMin
  priceAtBooking     Decimal?          @db.Decimal(10, 2)
  // Snapshot of the add-ons chosen at booking: [{name, durationMin, price}].
  // endsAt already includes their duration and priceAtBooking already includes
  // their price; this JSON preserves the itemized list for display even if an
  // add-on is later edited/deleted. [] = no add-ons (every pre-feature row).
  addOns             Json              @default("[]")
  manageToken        String            @unique // cancel/reschedule auth (no login)
  visitId            String?           @unique // the Visit promoted from this appointment
  visit              Visit?            @relation(fields: [visitId], references: [id], onDelete: SetNull)
  confirmationSentAt DateTime? // SMS confirmation stamp (at-most-once)
  reminderSentAt     DateTime? // SMS reminder stamp (at-most-once)
  // Email is a SEPARATE channel from SMS with its own idempotency: a customer can
  // get BOTH a text and an email (like Acuity), and email can go out even while
  // SMS is dark (no 10DLC / no consent). Email only needs a valid address.
  confirmationEmailSentAt DateTime?
  reminderEmailSentAt     DateTime?
  // PUSH reminders (engines/pushReminders.ts) - a third channel with two tiers
  // (24h + 2h before start), each with its own at-most-once stamp claimed via
  // an atomic updateMany-where-null, so a double/concurrent run can never send
  // twice. Gated per shop by pushReminder24h/2hEnabled.
  reminder24hPushSentAt DateTime?
  reminder2hPushSentAt  DateTime?
  canceledAt         DateTime?
  completedAt        DateTime?
  // Recurring series link. null = a one-off appointment (every row before this
  // feature). Each occurrence of a "every N weeks" booking is a normal
  // Appointment row so reminders/promotion/loyalty/slot-opened work unchanged;
  // seriesId just groups them for "cancel this + all future". SetNull (not
  // Cascade) so canceling a series never deletes an already-COMPLETED occurrence
  // whose Visit/PunchLedger granted punches. seriesOccurrenceIndex is the 0-based
  // position for ordering "this and future".
  seriesId              String?
  series                RecurringSeries?  @relation(fields: [seriesId], references: [id], onDelete: SetNull)
  seriesOccurrenceIndex Int?
  // AI-receptionist soft-lock. non-null = this PENDING row is a HOLD placed by
  // the receptionist while a client decides ("want Thu 2:30?"), not a real
  // request-before-booking request. An ACTIVE hold (holdExpiresAt > now) blocks
  // the slot exactly like any PENDING row; an EXPIRED one is excluded from the
  // busy set + overlap guards (and swept to CANCELED) so it releases the slot
  // without a slot-opened blast. Cleared (set null) when the hold is booked.
  holdExpiresAt DateTime?
  // Origin marker: "receptionist" for AI-created rows; null for everything else.
  bookedVia     String?
  // Client check-in ("On my way"). A nullable TEXT sub-state of BOOKED, not an
  // AppointmentStatus value (enum adds need an isolated migration; the string
  // mirrors bookedVia). null = not checked in; 'en_route' = the client tapped
  // "On my way" on the manage page (checkedInAt stamps the FIRST tap and never
  // moves; repeat taps only refresh the ETA); 'arrived' = the barber marked
  // them in the chair. The client route can ONLY write 'en_route' on their own
  // manageToken; 'arrived' is dashboard-only. etaMinutes is the optional chip
  // (5/10/15); runningLate is the "Running late" chip - both purely advisory.
  checkInStatus String?
  checkedInAt   DateTime?
  etaMinutes    Int?
  runningLate   Boolean   @default(false)
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt

  payment Payment? // the customer payment for this booking (if any)
  nudges  Nudge[] // appointment-scoped sends (checkin_nudge + replies)
  // Set when this booking claimed a barber-published targeted slot.
  targetedSlot TargetedSlot?

  // The double-booking guard (a partial unique on BOOKED rows) is added by hand
  // in the migration - Prisma can't express a WHERE-filtered unique index.
  @@index([shopId, staffId, startsAt]) // overlap checks + barber day view
  @@index([status, startsAt]) // reminder + promotion scans
  @@index([shopId, status, startsAt]) // dashboard upcoming list
  @@index([seriesId]) // "future rows of this series" lookups for cancel-scope
  @@index([status, holdExpiresAt]) // expired-hold sweep + busy-set exclusion
}

enum RecurringSeriesStatus {
  ACTIVE // still generating / has future occurrences
  ENDED // ran to its natural count/until
  CANCELED // barber/customer killed the remaining occurrences
}

// A "repeats every N weeks" booking. The recurrence RULE lives here; each
// concrete occurrence is materialized as a normal Appointment row (seriesId FK)
// so reminders / promotion / loyalty / slot-opened all keep working unchanged -
// this table only exists to group them for whole-series cancel. The rule is
// stored SHOP-LOCAL (weekday + minutes from local midnight) so occurrence
// instants are recomputed per date via zonedWallTimeToUtc and stay correct
// across DST (never add 7*24h in UTC). Exactly one of count / untilDate is set.
model RecurringSeries {
  id        String @id @default(cuid())
  shopId    String
  shop      Shop   @relation(fields: [shopId], references: [id], onDelete: Cascade)
  staffId   String
  staff     Staff  @relation(fields: [staffId], references: [id], onDelete: Restrict)
  serviceId String
  service   Service @relation(fields: [serviceId], references: [id], onDelete: Restrict)
  clientId  String?
  client    Client? @relation(fields: [clientId], references: [id], onDelete: SetNull)

  // Booker snapshot (survives client archive/merge), mirrors Appointment.
  firstName String
  lastName  String?
  phone     String?
  email     String?

  // Recurrence rule (shop-local). interval = every N weeks; weekday 0=Sun..6=Sat;
  // startMin = minutes from shop-local midnight. Exactly one of count/untilDate.
  interval  Int       @default(1)
  weekday   Int
  startMin  Int
  count     Int?
  untilDate DateTime? // UTC instant; occurrences generated up to this day's end

  status      RecurringSeriesStatus @default(ACTIVE)
  manageToken String                @unique // login-less whole-series cancel

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  appointments Appointment[]

  @@index([shopId, status])
  @@index([shopId, staffId])
}

// How a shop takes CUSTOMER payments for native bookings (distinct from the
// platform SUBSCRIPTION billing). Default off = customer pays in person.
//   off   = no charge; pay in person (every existing + new shop).
//   ahead = charge the full price at booking time.
//   hold  = authorize at booking, capture when the barber marks the appt done
//           (only for appts < ~6 days out; card auths expire ~7 days).
enum PaymentsMode {
  off
  ahead
  hold
}

// One customer payment for one native Appointment, via the shop's connected
// Stripe (Connect Express) account. Money settles to the BARBER (destination
// charge + on_behalf_of); the platform is the control plane only. FORCE RLS like
// the other tenant tables; the public booking route + the Connect webhook write
// as the connection owner (same bypass the Appointment insert uses), the barber
// reads via forShop(). Amounts are integer CENTS. mode/amount/connectAccountId
// are SNAPSHOTTED so an in-flight charge is immune to later toggle/account flips.
model Payment {
  id                     String       @id @default(cuid())
  shopId                 String
  shop                   Shop         @relation(fields: [shopId], references: [id], onDelete: Cascade)
  appointmentId          String       @unique
  appointment            Appointment  @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  stripePaymentIntentId  String       @unique
  stripeChargeId         String?
  stripeConnectAccountId String // snapshot of the shop's acct_ at charge time
  mode                   PaymentsMode // snapshot (ahead | hold)
  amount                 Int // cents, snapshot from Appointment.priceAtBooking
  currency               String       @default("usd")
  applicationFeeAmount   Int          @default(0) // platform fee in cents (0 for v1)
  // Mirrors the Stripe PaymentIntent status:
  // requires_payment_method | requires_action | requires_capture | processing |
  // succeeded | canceled | failed | refunded | partially_refunded
  status                 String       @default("requires_payment_method")
  capturedAmount         Int? // cents actually captured (hold mode)
  refundedAmount         Int          @default(0) // cents refunded so far
  authorizedAt           DateTime? // when the hold was placed (hold mode)
  holdExpiresAt          DateTime? // ~auth+6.5d; the release sweep watches this
  capturedAt             DateTime?
  // Webhook replay guard: last processed Stripe event id for this row.
  lastWebhookEventId     String?
  createdAt              DateTime     @default(now())
  updatedAt              DateTime     @updatedAt

  @@index([shopId, status])
  @@index([status, holdExpiresAt]) // the hold-release/capture-retry sweep
}

// Cross-replica mutex for the in-process node-cron scheduler. One row per named
// job. A replica "wins" a tick by UPDATE-ing the row only when the lease is free
// or expired (expiresAt < now); if 0 rows update, another replica holds it and
// this one no-ops. This is what makes the API safe to run on >1 replica without
// every replica re-firing the same cron tick (= duplicate customer texts).
//
// Pooler-safe by design: the acquire is a single atomic UPDATE, NOT a session
// advisory lock (a bare pg_advisory_lock can't be held across queries through
// PgBouncer transaction-mode). Self-healing: a crashed holder's lease simply
// expires and the next tick re-acquires. See apps/api/src/scheduler/lease.ts.
//
// Non-tenant utility table: RLS is ENABLED with NO policy (deny-all for the
// Supabase data API roles; the postgres owner the app connects as bypasses RLS),
// matching the 20260609000000 lockdown pattern. NOT force-RLS.
model JobLease {
  name      String   @id // e.g. "nudge-sweep", "appointment-reminders"
  holder    String   @default("") // replica id (hostname:pid); "" = never held
  expiresAt DateTime @default(now()) // now+ttl while held; past = free
  updatedAt DateTime @updatedAt

  @@map("job_lease")
}

//  AI receptionist

// One SMS thread between a client phone number and ONE shop's AI receptionist.
// The row pins the shop for the thread's lifetime, which is what makes replies
// on the SHARED platform number route deterministically (an active conversation
// wins over any client-phone-match heuristic). Created from the Twilio webhook
// path (no shop session), so inserts run as the connection owner and bypass
// FORCE RLS - the same trust model as WaitlistEntry/AppointmentRequest - and
// the barber reads transcripts back through forShop() (RLS-enforced).
model ReceptionistConversation {
  id       String  @id @default(cuid())
  shopId   String
  shop     Shop    @relation(fields: [shopId], references: [id], onDelete: Cascade)
  clientId String?
  client   Client? @relation(fields: [clientId], references: [id], onDelete: SetNull)
  phone    String // E.164
  // active    = the AI answers inbound texts on this thread
  // escalated = handed to the barber; the AI stays silent until reopened
  // closed    = ended (24h inactivity sweep, STOP, or resolved)
  status String @default("active")
  // Optimistic per-conversation turn lock: a worker claims a turn by setting
  // this from null; a second inbound while claimed just persists its message
  // (the running turn's rebuilt history picks it up). Stale (> ~2 min) = free.
  processingSince DateTime?
  lastMessageAt   DateTime @default(now())
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  messages ReceptionistMessage[]

  @@index([shopId, phone, status])
  @@index([phone, status, lastMessageAt]) // inbound routing: active-conversation pin
  @@index([status, lastMessageAt]) // auto-close sweep
}

// One turn in a receptionist conversation. The full audit trail: every inbound
// client text (role "user"), every AI reply (role "assistant", with the tool
// calls it made that turn in toolCalls), and system notes (escalations, holds
// expiring, gap-fill seeds) as role "system_note". toolCalls is an array of
// {name, input, result, isError} - the complete record of what the AI did.
model ReceptionistMessage {
  id             String                   @id @default(cuid())
  shopId         String // denormalized from the conversation for uniform RLS
  shop           Shop                     @relation(fields: [shopId], references: [id], onDelete: Cascade)
  conversationId String
  conversation   ReceptionistConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  role           String // "user" | "assistant" | "system_note"
  content        String
  toolCalls      Json                     @default("[]")
  createdAt      DateTime                 @default(now())

  @@index([conversationId, createdAt])
  @@index([shopId, createdAt])
}
