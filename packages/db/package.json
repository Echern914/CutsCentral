    "postinstall": "prisma generate"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@chairback/config": "workspace:*",
    "@prisma/client": "^5.20.0",
    "argon2": "^0.41.1",
    "prisma": "^5.20.0",
    "tsx": "^4.19.1"
  },
  "devDependencies": {
    "@types/node": "^20.16.5",
    "typescript": "^5.6.2",
    "vitest": "^2.1.1"
  }
}
