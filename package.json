{
  "name": "chairback",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "turbo run build",
    "predev": "node scripts/guard-dev-db.mjs",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "db:generate": "pnpm --filter @chairback/db generate",
    "db:migrate": "pnpm --filter @chairback/db migrate:dev",
    "db:seed": "pnpm --filter @chairback/db seed"
  },
  "devDependencies": {
    "turbo": "^2.1.3",
    "typescript": "^5.6.2"
  }
}
